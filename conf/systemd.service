[Unit]
Description=Docker Gate for YunoHost
After=network.target docker.service

[Service]
Type=simple
User=__APP__
Group=__APP__
WorkingDirectory=__INSTALL_DIR__
Environment="PATH=__INSTALL_DIR__/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
ExecStart=__INSTALL_DIR__/venv/bin/gunicorn --workers 1 --bind 127.0.0.1:__PORT__ app:app
Restart=on-failure
RestartSec=5

# Basic hardening
PrivateTmp=true

[Install]
WantedBy=multi-user.target
