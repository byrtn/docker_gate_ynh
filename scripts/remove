#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# WARNING (non-blocking): child apps still tracked
#=================================================
# Step 2 (2026-07-11), fixed on 2026-07-17 (security/quality audit,
# docs/02-wappos/audits/2026-07-17-audit-cycle-backup-restore.md): a
# `ynh_die` here used to claim it would fully block removal. WRONG IN
# PRACTICE — verified by a real end-to-end test on 2026-07-17: YunoHost
# core deprovisions the resources declared in manifest.toml anyway (ports,
# SSO permission, install_dir, system user) AFTER this script fails,
# whether we like it or not — a `ynh_die` here only prevents THIS script
# from finishing its own cleanup properly (nginx/systemd/sudoers), leaving
# extra orphaned residual files behind, without actually preventing
# anything.
#
# Decision made: warn honestly rather than promise a guarantee that's
# technically impossible to keep, and let removal run to completion
# cleanly (no nginx/systemd/sudoers residue). Good news confirmed by the
# same test: the child apps themselves (the YunoHost "redirect" app, its
# Docker container, its nginx config) are NOT affected — only Docker
# Gate's own memory of them (`data/apps.json`) is lost. Reinstalling
# Docker Gate then detects these containers as orphan residue via the
# /audit page (tested and confirmed).
data_file="$install_dir/data/apps.json"
if [ -f "$data_file" ] && [ "$(cat "$data_file" 2>/dev/null | grep -c '"slug"')" -gt 0 ]; then
    app_count="$(python3 -c "import json; print(len(json.load(open('$data_file'))))" 2>/dev/null || echo '?')"

    # Bilingualism (audit workstream 7, 2026-07-17): these custom messages
    # (safety guard, interactive question) get NO automatic translation
    # from YunoHost — unlike the manifest's declarative questions
    # (domain/path/language), these are plain `ynh_print_warn`/`read` bash
    # calls, always shown in whatever language is hardcoded in the
    # package, regardless of the admin. Fixed by reusing the language
    # preference already recorded by the app itself
    # (`data/default_language.txt`, written by install/upgrade/restore,
    # changeable from the web interface) — read here while `$install_dir`
    # still exists (before deprovisioning).
    lang="$(cat "$install_dir/data/default_language.txt" 2>/dev/null)"
    [ "$lang" = "fr" ] || lang="en"

    if [ "$lang" = "fr" ]; then
        msg_children_exist="Des apps Docker créées via Docker Gate existent encore ($app_count)."
        msg_question="Souhaitez-vous également supprimer les applications ET leurs données gérées par Docker Gate ? Réponds explicitement 'oui' ou 'non' :"
        msg_unrecognized_prefix="Réponse non reconnue"
        msg_unrecognized_suffix="— tape uniquement 'oui' ou 'non', rien d'autre."
        msg_noninteractive="Des apps Docker créées via Docker Gate existent encore ($app_count) — suppression non-interactive, elles ne sont PAS supprimées automatiquement par sécurité. Elles continueront de tourner et de consommer Docker CE : si tu comptes aussi désinstaller Docker CE plus tard, fais-le AVANT de supprimer Docker Gate (bouton 'Désinstaller Docker CE' de la page Audit), sinon plus aucun avertissement ne sera possible une fois Docker Gate parti."
        msg_progress="Suppression des $app_count app(s) gérées par Docker Gate (avec leurs données)..."
        msg_kept="Les apps ne seront PAS touchées : leurs conteneurs Docker et leur exposition YunoHost restent en place, mais Docker Gate perdra leur suivi. Après une éventuelle réinstallation, retrouve-les via la page 'Audit & nettoyage' (conteneurs orphelins). Pour les supprimer plus tard, utilise le bouton 'Supprimer' de chaque app depuis l'interface. ATTENTION : ces apps ont toujours besoin de Docker CE pour fonctionner — si tu prévois de désinstaller Docker CE (question suivante ou plus tard), ces apps cesseront de fonctionner tant que Docker CE n'est pas réinstallé."
    else
        msg_children_exist="Docker apps created via Docker Gate still exist ($app_count)."
        msg_question="Do you also want to remove the applications AND their data managed by Docker Gate? Answer explicitly 'yes' or 'no':"
        msg_unrecognized_prefix="Unrecognized answer"
        msg_unrecognized_suffix="— type only 'yes' or 'no', nothing else."
        msg_noninteractive="Docker apps created via Docker Gate still exist ($app_count) — non-interactive removal, they are NOT automatically deleted for safety. They will keep running and keep relying on Docker CE: if you also plan to uninstall Docker CE later, do it BEFORE removing Docker Gate (the 'Uninstall Docker CE' button on the Audit page), otherwise no further warning will be possible once Docker Gate is gone."
        msg_progress="Removing $app_count app(s) managed by Docker Gate (with their data)..."
        msg_kept="The apps will NOT be touched: their Docker containers and YunoHost exposure remain in place, but Docker Gate will lose track of them. After a later reinstall, find them again via the 'Audit & cleanup' page (orphan containers). To remove them later, use the 'Delete' button on each app from the interface. WARNING: these apps still need Docker CE to work — if you plan to uninstall Docker CE (next question, or later), these apps will stop working until Docker CE is reinstalled."
    fi

    # Interactive question (2026-07-17, explicitly requested by Patrick
    # following the 2026-07-17 finding on this same workstream): rather
    # than silently letting child apps become orphaned, explicitly offer
    # to remove them WITH their data at the same time as Docker Gate.
    # Protected by `[ -t 0 ]` (only if a real terminal is attached, same as
    # for the manifest's install questions) — never a blocking `read` on a
    # non-interactive call (API, script), which then keeps the safe
    # default behavior (nothing is touched, just a warning).
    remove_children=0
    if [ -t 0 ]; then
        # Important (found on 2026-07-17 under real conditions): `read -p`
        # writes its prompt text to a channel that YunoHost's display (the
        # job runner) does NOT show reliably — the question was invisible
        # to the admin, who only saw silence before having to guess that
        # typing an answer was expected. Fixed by printing the question via
        # `ynh_print_warn` (same channel, same "Warning:" style as the rest
        # of the already-visible messages), then a `read` WITHOUT its own
        # prompt, which just captures the typed line.
        ynh_print_warn --message="$msg_children_exist"
        # An EXPLICIT answer is required (requested by Patrick on
        # 2026-07-17) — a bare Enter or an unrecognized answer loops back
        # to the question instead of silently choosing "no" on the admin's
        # behalf.
        answer=""
        while true; do
            ynh_print_warn --message="$msg_question"
            read -r answer
            case "$answer" in
                [oO][uU][iI]|[yY][eE][sS])
                    remove_children=1
                    break
                    ;;
                [nN][oO][nN]|[nN][oO])
                    remove_children=0
                    break
                    ;;
                *)
                    ynh_print_warn --message="$msg_unrecognized_prefix ('$answer') $msg_unrecognized_suffix"
                    ;;
            esac
        done
    else
        ynh_print_warn --message="$msg_noninteractive"
    fi

    if [ "$remove_children" -eq 1 ]; then
        ynh_script_progression --message="$msg_progress" --weight=15
        # Directly reuses remove_docker_app() (same 3-layer logic, same
        # checks as removal via the web interface) rather than
        # reimplementing removal in bash — a single source of truth for
        # "how an app gets removed".
        "$venv_dir/bin/python3" - <<PYEOF
import sys
sys.path.insert(0, "$install_dir")
import ynh_manager

apps = ynh_manager._load_state()
for entry in list(apps):
    slug = entry.get("slug", "?")
    try:
        warnings = ynh_manager.remove_docker_app(slug, "$lang", delete_data=True, delete_domain=True)
        status = "removed" if not warnings else f"removed with warning(s): {'; '.join(warnings)}"
        print(f"  - {slug}: {status}")
    except Exception as e:
        print(f"  - {slug}: FAILED ({e})")
PYEOF
    else
        ynh_print_warn --message="$msg_kept"
    fi
fi

#=================================================
# INTERACTIVE QUESTION: also uninstall Docker CE?
#=================================================
# Added on 2026-07-18 (Patrick's request during the full cold
# reinstallation test): Docker Gate installs Docker CE automatically at
# install time (see ynh_docker_gate__ensure_docker_installed in
# _common.sh) — symmetrically, offer to uninstall it here too rather than
# always leaving it in place. Same `[ -t 0 ]` protection as the question
# above, never blocking on a non-interactive call (safe default: Docker CE
# is never touched without explicit confirmation).
if command -v docker >/dev/null 2>&1; then
    lang="$(cat "$install_dir/data/default_language.txt" 2>/dev/null)"
    [ "$lang" = "fr" ] || lang="en"

    # Lists containers still present at this point, split into two
    # categories: those still managed by Docker Gate (container_name known
    # from data/apps.json — present if the admin chose to keep them above,
    # or on a non-interactive call) and everything else, entirely unrelated
    # to Docker Gate. Purging Docker CE destroys BOTH categories without
    # distinction — warning only about "foreign" containers would have
    # given a false sense of safety as long as no third-party app was
    # present, while apps still managed (e.g. Portainer kept above) would
    # stop working just the same (point raised by Patrick on 2026-07-18
    # after a real end-to-end test).
    tracked_names=""
    if [ -f "$data_file" ]; then
        tracked_names="$("$venv_dir/bin/python3" -c "
import json
try:
    apps = json.load(open('$data_file'))
    print(' '.join(a.get('container_name', '') for a in apps))
except Exception:
    pass
" 2>/dev/null)"
    fi
    tracked_containers=""
    foreign_containers=""
    for c in $(docker ps -aq --format '{{.Names}}' 2>/dev/null); do
        case " $tracked_names " in
            *" $c "*) tracked_containers="$tracked_containers $c" ;;
            *) foreign_containers="$foreign_containers $c" ;;
        esac
    done
    tracked_containers="${tracked_containers# }"
    foreign_containers="${foreign_containers# }"

    if [ "$lang" = "fr" ]; then
        docker_question="Voulez-vous également désinstaller Docker CE (paquets, /var/lib/docker, groupe docker) ? Docker Gate l'avait installé automatiquement. Réponds explicitement 'oui' ou 'non' :"
        docker_tracked_warn="ATTENTION : $tracked_containers tourne(nt) encore et sont géré(s) par Docker Gate (que tu as choisi de garder) — le(s) arrêter avec Docker CE les rendra inutilisables tant que Docker CE n'est pas réinstallé."
        docker_foreign_warn="ATTENTION : au moins un conteneur Docker non géré par Docker Gate tourne encore sur cette machine ($foreign_containers) — le purger avec Docker CE le détruira AUSSI, données comprises, sans rapport avec cette app."
        docker_noninteractive="Docker CE reste installé (suppression non-interactive, jamais touché sans confirmation explicite)."
        docker_progress="Désinstallation complète de Docker CE..."
        docker_kept="Docker CE reste installé sur cette machine."
        unrec_prefix="Réponse non reconnue"
        unrec_suffix="— tape uniquement 'oui' ou 'non', rien d'autre."
    else
        docker_question="Do you also want to uninstall Docker CE (packages, /var/lib/docker, docker group)? Docker Gate installed it automatically. Answer explicitly 'yes' or 'no':"
        docker_tracked_warn="WARNING: $tracked_containers is/are still running and managed by Docker Gate (which you chose to keep) — stopping it/them along with Docker CE will make it/them unusable until Docker CE is reinstalled."
        docker_foreign_warn="WARNING: at least one Docker container not managed by Docker Gate is still running on this machine ($foreign_containers) — purging it along with Docker CE will ALSO destroy it, data included, unrelated to this app."
        docker_noninteractive="Docker CE is left installed (non-interactive removal, never touched without explicit confirmation)."
        docker_progress="Fully uninstalling Docker CE..."
        docker_kept="Docker CE remains installed on this machine."
        unrec_prefix="Unrecognized answer"
        unrec_suffix="— type only 'yes' or 'no', nothing else."
    fi

    remove_docker=0
    if [ -t 0 ]; then
        if [ -n "$tracked_containers" ]; then
            ynh_print_warn --message="$docker_tracked_warn"
        fi
        if [ -n "$foreign_containers" ]; then
            ynh_print_warn --message="$docker_foreign_warn"
        fi
        answer=""
        while true; do
            ynh_print_warn --message="$docker_question"
            read -r answer
            case "$answer" in
                [oO][uU][iI]|[yY][eE][sS])
                    remove_docker=1
                    break
                    ;;
                [nN][oO][nN]|[nN][oO])
                    remove_docker=0
                    break
                    ;;
                *)
                    ynh_print_warn --message="$unrec_prefix ('$answer') $unrec_suffix"
                    ;;
            esac
        done
    else
        ynh_print_warn --message="$docker_noninteractive"
    fi

    if [ "$remove_docker" -eq 1 ]; then
        ynh_script_progression --message="$docker_progress" --weight=15
        systemctl stop docker docker.socket containerd 2>/dev/null || true
        apt-get purge -y docker-ce docker-ce-cli docker-ce-rootless-extras docker-buildx-plugin docker-compose-plugin containerd.io >/dev/null 2>&1 || true
        apt-get autoremove -y >/dev/null 2>&1 || true
        rm -rf /var/lib/docker /var/lib/containerd /etc/docker
        rm -f /etc/apt/sources.list.d/docker.list /etc/apt/keyrings/docker.gpg
        groupdel docker 2>/dev/null || true
    else
        ynh_print_warn --message="$docker_kept"
    fi
fi

ynh_script_progression --message="Stopping and removing the service..." --weight=10

if yunohost service status "$app" >/dev/null 2>&1; then
    yunohost service remove "$app"
fi

systemctl stop "$app" 2>/dev/null || true
systemctl disable "$app" 2>/dev/null || true

ynh_script_progression --message="Removing the nginx configuration..." --weight=5
ynh_remove_nginx_config

ynh_script_progression --message="Removing the sudo rights..." --weight=5
rm -f /etc/sudoers.d/docker_gate

ynh_script_progression --message="Removing the systemd configuration..." --weight=5
ynh_remove_systemd_config

# NB: install_dir, the app's SSO permission, and its system user are
# automatically deprovisioned by YunoHost core after this script
# (resources declared in manifest.toml) — no need to do it here.

ynh_script_progression --message="Removal completed." --last
