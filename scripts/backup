#!/bin/bash
#
# Backs up Docker Gate itself (files, config, apps.json state) ONLY — does
# NOT cover the containers/volumes/data of the Docker apps managed through
# the interface. A deliberate choice, not an oversight: see doc/ADMIN.md
# ("What Docker Gate does NOT do") for the full detail and rationale.

source "$(dirname "$0")/_common.sh"
source /usr/share/yunohost/helpers

ynh_script_progression --message="Backing up the app's files..."
ynh_backup --src_path="$install_dir"

ynh_script_progression --message="Backing up the nginx configuration..."
ynh_backup --src_path="/etc/nginx/conf.d/$domain.d/$app.conf"

ynh_script_progression --message="Backing up the systemd configuration..."
ynh_backup --src_path="/etc/systemd/system/$app.service"

ynh_script_progression --message="Backup completed." --last
