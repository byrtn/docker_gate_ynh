#!/bin/bash

source "$(dirname "$0")/_common.sh"
source /usr/share/yunohost/helpers

# Path to the package root, resolved from this script's REAL location
# (real backup/restore test audit, 2026-07-17) — never from the current
# working directory. `../conf/...` happened to work in install/upgrade
# (YunoHost runs the script there with `scripts/` as the working
# directory), but a real `yunohost backup restore` test confirmed this is
# NOT true during a restore (different working directory) — the script
# used to crash on `cp ../conf/docker_gate.sudoers` with a "No such file or
# directory". `$(dirname "$0")` works in ALL contexts (already used for
# `_common.sh` just above).
pkg_dir="$(dirname "$0")/.."

#=================================================
# INSTALL DOCKER (if needed)
#=================================================
ynh_script_progression --message="Checking / installing Docker CE..." --weight=30

ynh_docker_gate__ensure_docker_installed

# The app's system user needs to be able to drive Docker
usermod -aG docker "$app"

#=================================================
# DEPLOY SOURCE FILES
#=================================================
ynh_script_progression --message="Deploying the app's files..." --weight=5

mkdir -p "$install_dir"
cp -ar "$pkg_dir/sources/." "$install_dir/"

# Copy the sudoers template and the logo INTO install_dir (real
# backup/restore test audit, 2026-07-17 — 2nd fix): a first fix based on
# `$(dirname "$0")` turned out to be insufficient — verified under real
# conditions that during a restore, YunoHost only makes the `scripts/`
# folder available (where this script lives), NOT the package's
# `conf/`/`logo.png`/`sources/`. `install_dir` itself is faithfully
# restored from the backup archive (already contains `sources/`) — also
# copying these 2 files into it makes them available identically during
# install/upgrade AND during restore, without depending on a `conf/`
# folder that isn't necessarily present next to the script at runtime.
mkdir -p "$install_dir/.package"
cp "$pkg_dir/conf/docker_gate.sudoers" "$install_dir/.package/docker_gate.sudoers"
cp "$pkg_dir/logo.png" "$install_dir/.package/logo.png"

# Default interface language (see manifest.toml, default_language
# question) — fallback used by app.py as long as the user hasn't
# explicitly chosen one via the interface's EN/FR switcher (cookie).
mkdir -p "$install_dir/data"
echo -n "$default_language" > "$install_dir/data/default_language.txt"

#=================================================
# PYTHON VENV
#=================================================
ynh_script_progression --message="Setting up the Python environment..." --weight=15

python3 -m venv "$venv_dir"
"$venv_dir/bin/pip" install --upgrade pip
"$venv_dir/bin/pip" install -r "$install_dir/requirements.txt"

#=================================================
# PERMISSIONS
#=================================================
chown -R "$app:$app" "$install_dir"
chmod 750 "$install_dir"

#=================================================
# SUDOERS (targeted rights, see conf/docker_gate.sudoers)
#=================================================
ynh_script_progression --message="Configuring the targeted sudo rights..." --weight=5

cp "$install_dir/.package/docker_gate.sudoers" /etc/sudoers.d/docker_gate
sed -i "s/__APP__/$app/g" /etc/sudoers.d/docker_gate
chmod 440 /etc/sudoers.d/docker_gate
chown root:root /etc/sudoers.d/docker_gate
visudo -c -f /etc/sudoers.d/docker_gate || ynh_die --message="The generated sudoers file is invalid, installation aborted for safety."

#=================================================
# LOGO (YunoHost admin panel AND user portal)
#=================================================
# Two DISTINCT mechanisms, discovered on 2026-07-15 (the first one alone
# isn't enough — logo visible in the admin panel but missing from the
# portal tile):
# 1) Admin panel (yunohost/app.py, app_info function): a local
#    customization trick for apps outside the official catalog — a file
#    named "$app.png" in /usr/share/yunohost/applogos/ is used with
#    priority if it exists.
# 2) User portal tile (yunohost/app.py, app_portal_info): reads ONLY the
#    logo_hash stored on the "$app.main" permission — unrelated to the
#    "$app.png" file from point 1. Set via the official command
#    "yunohost user permission update $app.main --logo <file>"
#    (yunohost/permission.py), which computes the hash and places the file
#    itself — never a need to do it by hand.
ynh_script_progression --message="Installing the logo..." --weight=2

mkdir -p /usr/share/yunohost/applogos
install -o root -g root -m 0644 "$install_dir/.package/logo.png" "/usr/share/yunohost/applogos/$app.png"
yunohost user permission update "$app.main" --logo "$install_dir/.package/logo.png"

#=================================================
# SYSTEMD CONFIGURATION
#=================================================
ynh_script_progression --message="Configuring the systemd service..." --weight=5

ynh_add_systemd_config

#=================================================
# NGINX CONFIGURATION
#=================================================
ynh_script_progression --message="Configuring the web server..." --weight=5

ynh_add_nginx_config

#=================================================
# START SERVICE
#=================================================
ynh_script_progression --message="Starting Docker Gate..." --weight=10

yunohost service add "$app" --description="Docker Gate for YunoHost" --log="/var/log/$app/$app.log"

systemctl enable "$app"
systemctl start "$app"

ynh_script_progression --message="Installation completed." --last
