#!/bin/bash

source "$(dirname "$0")/_common.sh"
source /usr/share/yunohost/helpers

# See scripts/install for the full explanation (real backup/restore test
# audit, 2026-07-17) — path resolved from the script's real location, never
# from the current working directory.
pkg_dir="$(dirname "$0")/.."

ynh_script_progression --message="Stopping the service..." --weight=5
systemctl stop "$app" 2>/dev/null || true

ynh_script_progression --message="Checking Docker..." --weight=10
ynh_docker_gate__ensure_docker_installed
usermod -aG docker "$app"

ynh_script_progression --message="Updating the app's files..." --weight=5
cp -ar "$pkg_dir/sources/." "$install_dir/"

# See scripts/install for the full explanation (2nd backup/restore fix,
# 2026-07-17) — copied INTO install_dir, faithfully restored from the
# archive, unlike the package's own conf/logo.png.
mkdir -p "$install_dir/.package"
cp "$pkg_dir/conf/docker_gate.sudoers" "$install_dir/.package/docker_gate.sudoers"
cp "$pkg_dir/logo.png" "$install_dir/.package/logo.png"

ynh_script_progression --message="Updating the Python environment..." --weight=15
"$venv_dir/bin/pip" install --upgrade pip
"$venv_dir/bin/pip" install -r "$install_dir/requirements.txt"

chown -R "$app:$app" "$install_dir"
chmod 750 "$install_dir"

ynh_script_progression --message="Updating the targeted sudo rights..." --weight=5
cp "$install_dir/.package/docker_gate.sudoers" /etc/sudoers.d/docker_gate
sed -i "s/__APP__/$app/g" /etc/sudoers.d/docker_gate
chmod 440 /etc/sudoers.d/docker_gate
chown root:root /etc/sudoers.d/docker_gate
visudo -c -f /etc/sudoers.d/docker_gate || ynh_die --message="The generated sudoers file is invalid, update aborted for safety."

ynh_script_progression --message="Updating the logo..." --weight=2
mkdir -p /usr/share/yunohost/applogos
install -o root -g root -m 0644 "$install_dir/.package/logo.png" "/usr/share/yunohost/applogos/$app.png"
yunohost user permission update "$app.main" --logo "$install_dir/.package/logo.png"

ynh_script_progression --message="Updating the systemd configuration..." --weight=5
ynh_add_systemd_config

ynh_script_progression --message="Updating the nginx configuration..." --weight=5
ynh_add_nginx_config

ynh_script_progression --message="Restarting the service..." --weight=5
systemctl restart "$app"

ynh_script_progression --message="Upgrade completed." --last
